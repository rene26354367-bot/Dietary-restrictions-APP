# ── 後端環境變數（Railway 設定） ──────────────────────────────────────────────
# Gemini AI API Key（後端呼叫 Gemini 用）
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Google Cloud Vision API Key（後端 OCR 用，不要放到前端 VITE_ 開頭）
GOOGLE_CLOUD_VISION_KEY="YOUR_GOOGLE_VISION_KEY"

# 資料持久化目錄（Railway Volume 掛載路徑，本地留空自動使用專案根目錄）
DATA_DIR=/data

# 後端 Port（Railway 會自動提供 PORT，本地預設 3001）
PORT=3001

# ── 前端環境變數（Vercel 設定） ───────────────────────────────────────────────
# 前端呼叫後端的 Base URL（Railway 部署後填入）
# 注意：只設這一個，不要把 API Key 放到 VITE_ 開頭的變數（會暴露在 JS bundle）
VITE_API_BASE=https://your-app.railway.app
